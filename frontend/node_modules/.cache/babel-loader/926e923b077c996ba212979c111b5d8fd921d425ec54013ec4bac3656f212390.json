ort './FoodItem.css';\r\nimport { assets } from '../../assets/frontend_assets/assets';\r\nimport { StoreContext } from '../../Context/StoreContext';\r\n\r\nconst FoodItem = ({id,name,price,description,image}) => {\r\n  const{cartItem,addToCart,removeFromCart,url} = useContext(StoreContext);\r\n\r\n  return (\r\n    <div className='food-item'>\r\n        <div className=\"food-item-img-container\">\r\n            <img className='food-item-image' src={url+ \"/images/\"+image} alt=\"\" />\r\n            {\r\n              !cartItem[id]\r\n              ? <img className='add' onClick={()=>addToCart(id)} src={assets.add_icon_white}/>\r\n              :\r\n              <div className='food-item-counter'>\r\n                <img onClick={()=>removeFromCart(id)} src={assets.remove_icon_red} alt=\"\" />\r\n                <p>{cartItem[id]}</p>\r\n                <img onClick={()=>addToCart(id)} src={assets.add_icon_green} alt=\"\" />\r\n              </div>\r\n            }\r\n        </div>\r\n        <div className=\"food-item-info\">\r\n            <div className=\"food-item-name-rating\">\r\n                <p>{name}</p>\r\n                <img src={assets.rating_starts} alt=\"\" />\r\n            </div>\r\n            <p className=\"food-item-desc\">\r\n                {description}\r\n            </p>\r\n            <div className=\"food-item-price\">\r\n              ₹{price}\r\n            </div>\r\n        </div>\r\n      \r\n    </div>\r\n  )\r\n}\r\n\r\nexport default FoodItem\r\n"],"mappings":"AAAA,MAAO,CAAAA,KAAK,EAAIC,UAAU,KAAO,OAAO,CACxC,MAAO,gBAAgB,CACvB,OAASC,MAAM,KAAQ,qCAAqC,CAC5D,OAASC,YAAY,KAAQ,4BAA4B,CAAC,OAAAC,GAAA,IAAAC,IAAA,CAAAC,IAAA,IAAAC,KAAA,yBAE1D,KAAM,CAAAC,QAAQ,CAAGC,IAAA,EAAuC,IAAtC,CAACC,EAAE,CAACC,IAAI,CAACC,KAAK,CAACC,WAAW,CAACC,KAAK,CAAC,CAAAL,IAAA,CACjD,KAAK,CAACM,QAAQ,CAACC,SAAS,CAACC,cAAc,CAACC,GAAG,CAAC,CAAGjB,UAAU,CAACE,YAAY,CAAC,CAEvE,mBACEI,KAAA,QAAKY,SAAS,CAAC,WAAW,CAAAC,QAAA,eACtBb,KAAA,QAAKY,SAAS,CAAC,yBAAyB,CAAAC,QAAA,eACpCf,IAA